FROM node:24-slim AS build

WORKDIR /app

COPY package.json /app/package.json
RUN npm install

ARG VITE_API_BASE_URL=http://localhost:8000/api
ARG VITE_APP_NAME=Postalia
ARG VITE_DEFAULT_LANGUAGE=en
ARG VITE_GOOGLE_CLIENT_ID=
ARG VITE_ENABLE_PAGE_ADS=false
ARG VITE_ADS_PROVIDER=mock
ARG VITE_GOOGLE_ADSENSE_CLIENT_ID=
ARG VITE_GOOGLE_ADSENSE_SLOT_HEADER=
ARG VITE_GOOGLE_ADSENSE_SLOT_SIDEBAR=
ARG VITE_GOOGLE_ADSENSE_SLOT_DASHBOARD=
ARG VITE_GOOGLE_ADSENSE_SLOT_FOOTER=
ARG VITE_CREEM_ENABLED=false
ARG VITE_ENABLE_REWARDED_ADS=false
ARG VITE_REWARDED_AD_PROVIDER=mock
ARG VITE_REWARDED_AD_POINTS=5
ARG VITE_REWARDED_AD_DAILY_LIMIT=2

ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
ENV VITE_APP_NAME=${VITE_APP_NAME}
ENV VITE_DEFAULT_LANGUAGE=${VITE_DEFAULT_LANGUAGE}
ENV VITE_GOOGLE_CLIENT_ID=${VITE_GOOGLE_CLIENT_ID}
ENV VITE_ENABLE_PAGE_ADS=${VITE_ENABLE_PAGE_ADS}
ENV VITE_ADS_PROVIDER=${VITE_ADS_PROVIDER}
ENV VITE_GOOGLE_ADSENSE_CLIENT_ID=${VITE_GOOGLE_ADSENSE_CLIENT_ID}
ENV VITE_GOOGLE_ADSENSE_SLOT_HEADER=${VITE_GOOGLE_ADSENSE_SLOT_HEADER}
ENV VITE_GOOGLE_ADSENSE_SLOT_SIDEBAR=${VITE_GOOGLE_ADSENSE_SLOT_SIDEBAR}
ENV VITE_GOOGLE_ADSENSE_SLOT_DASHBOARD=${VITE_GOOGLE_ADSENSE_SLOT_DASHBOARD}
ENV VITE_GOOGLE_ADSENSE_SLOT_FOOTER=${VITE_GOOGLE_ADSENSE_SLOT_FOOTER}
ENV VITE_CREEM_ENABLED=${VITE_CREEM_ENABLED}
ENV VITE_ENABLE_REWARDED_ADS=${VITE_ENABLE_REWARDED_ADS}
ENV VITE_REWARDED_AD_PROVIDER=${VITE_REWARDED_AD_PROVIDER}
ENV VITE_REWARDED_AD_POINTS=${VITE_REWARDED_AD_POINTS}
ENV VITE_REWARDED_AD_DAILY_LIMIT=${VITE_REWARDED_AD_DAILY_LIMIT}

COPY . /app
RUN npm run build

FROM node:24-slim AS dev

WORKDIR /app

COPY package.json /app/package.json
RUN npm install

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173", "--strictPort"]

FROM nginx:1.27-alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
